}
# 7. Add an overall master title at the very top
mtext("Cut Detection Response Times by Condition", outer = TRUE, cex = 1.3, font = 2)
plot(1)
dev.off()
plot(1)
# 1. Clean the data (remove NAs from the conditions to prevent plotting errors)
df_clean <- subset(df, !is.na(sound) & !is.na(subtitles))
# Open the PNG graphic device
png(filename = "histograms-plot-2.png", width = 20, height = 15, units = "cm", res = 300)
windowsFonts(TN = windowsFont("Times New Roman"))
# 2. Setup the plotting area for a 2x2 grid
# Applying family = "TN" here ensures all text uses Times New Roman
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1), oma = c(2, 0, 0, 0), family = "TN")
# 3. Use R's preconfigured named colors
# adjustcolor() allows us to use standard names while keeping the 70% opacity
col_first <- adjustcolor("blue", alpha.f = 0.7)
col_second <- adjustcolor("red", alpha.f = 0.7)
# 4. Define global x-axis limits based on your valid RT bounds (200ms to 1500ms)
x_lims <- c(200, 1500)
# Define exact breaks (bins) so the two histograms align perfectly
breaks_seq <- seq(x_lims[1], x_lims[2], length.out = 40)
# 5. Extract unique levels for the loop
sounds <- levels(as.factor(df_clean$sound))
subs <- levels(as.factor(df_clean$subtitles))
# 6. Loop through all 4 conditions to draw the plots
for(s in sounds) {
for(sub in subs) {
# Subset data for this specific 1-of-4 condition
d_cond <- subset(df_clean, sound == s & subtitles == sub)
# --- NEW TITLE LOGIC ---
# Translate the subtitle factor into clean English text
sub_text <- ifelse(sub == "sub", "with subtitles", "without subtitles")
# Combine the sound condition and the translated subtitle text (e.g., "audiovisual with subtitles")
plot_title <- paste(s, sub_text)
# -----------------------
# Extract Reaction Times and remove NAs
rt1 <- na.omit(d_cond$delay_first_cut)
rt2 <- na.omit(d_cond$delay_second_cut)
# Calculate histograms invisibly first to find the maximum Y-axis value
h1 <- hist(rt1, breaks = breaks_seq, plot = FALSE)
h2 <- hist(rt2, breaks = breaks_seq, plot = FALSE)
# Calculate y_max using DENSITY instead of counts
y_max <- max(c(h1$density, h2$density), na.rm = TRUE)
y_max <- 0.003
# Draw the First Cut histogram
# freq = FALSE forces it to plot relative density instead of absolute counts
hist(rt1, breaks = breaks_seq, col = col_first, border = "black",
xlim = x_lims, ylim = c(0, y_max * 1.1), freq = FALSE,
main = plot_title, # Uses the new readable title
xlab = "Response Time (ms)", ylab = "relative frequency")
# Overlay the Second Cut histogram on top
hist(rt2, breaks = breaks_seq, col = col_second, border = "black",
add = TRUE, freq = FALSE)
# Add a mini legend to the top right of each plot
legend("topright", legend = c("First Cut", "Second Cut"),
fill = c(col_first, col_second), bty = "n", cex = 0.8)
}
}
# 7. Add an overall master title at the very top
mtext("Cut Detection Response Times by Condition", outer = TRUE, cex = 1.3, font = 2)
# 8. Reset the plotting parameters back to default (1x1) so future plots behave normally
par(mfrow = c(1, 1), oma = c(0, 0, 0, 0))
# Close the device and save the image
dev.off()
# makes sure the predictors are factors
df_performance$participant <- as.factor(df_performance$participant)
df_performance$subtitles <- as.factor(df_performance$subtitles)
df_performance$sound <- as.factor(df_performance$sound)
performance_anova <- aov(proportion ~ subtitles * sound + Error(participant / (subtitles * sound)),
data = df_performance)
summary(performance_anova)
aggregate(proportion ~  sound + subtitles, df_performance, mean)
